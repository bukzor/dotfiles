{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read(~/.claude/context/**/CLAUDE.*.md)",
      "Bash(cp -i:*)",
      "Bash(mv -i:*)",
      "Bash(mkdir:*)",
      "Bash(rmdir:*)",
      "Bash(chmod:*)",
      "Bash(ps:*)",
      "Bash(alert:*)",
      "Bash(namei:*)"
    ],
    "deny": [
      "TodoWrite",
      "MultiEdit",
      "NotebookEdit"
    ],
    "additionalDirectories": [
      "~/.claude/context"
    ]
  },
  "model": "sonnet[1m]",
  "//hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "// HAY PROBLEMA": "this thing is showing up in *every* turn, when using --verbose. see: https://github.com/anthropics/claude-code/issues/5557",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/SessionStart.extra-context.sh"
          }
        ]
      }
    ]
  },
  "feedbackSurveyState": {
    "lastShownTime": 1754083893860
  }
}