{
  "permissions": {
    "allow": [
      "WebSearch",
      "WebFetch(domain:*)",
      "Glob",
      "Grep",
      "Bash(ls:*)",
      "Bash(pwd:*)",
      "Bash(find:*)",
      "Bash(which:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(less:*)",
      "Bash(wc:*)",
      "Bash(file:*)",
      "Bash(uname:*)",
      "Bash(ps:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git add:*)",
      "Bash(chmod:*)",
      "Bash(pnpm list:*)",
      "Bash(npm list:*)",
      "Bash(uv pip list:*)",
      "Bash(pip list:*)",
      "Bash(cargo --version:*)",
      "Bash(rustc --version:*)",
      "Bash(python --version:*)",
      "Bash(node --version:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(git add -A:*)",
      "Bash(git add --all:*)",
      "Bash(git add .:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(pnpm install:*)",
      "Bash(npm install:*)",
      "Bash(uv pip install:*)",
      "Bash(pip install:*)",
      "Bash(cargo install:*)",
      "Bash(git reset:*)"
    ],
    "additionalDirectories": [
      "~/.claude/must-read-before.d",
      "~/",
      "~/.claude"
    ]
  },
  "strict-mcp-config",
  "alwaysThinkingEnabled": true,
  "//hooks": {
    "//PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/git_commit_validator.py"
          }
        ]
      },
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/python_style_reminder.py"
          }
        ]
      }
    ]
  }
}
