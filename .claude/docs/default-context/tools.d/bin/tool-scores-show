#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = ["pyyaml"]
# ///
"""Compute tool cost/benefit metrics from x.yaml estimates."""

from pathlib import Path

import yaml


def get_definition_kb(tools_dir: Path, name: str) -> float:
    """Get definition size in kB from the tool's .md file."""
    md_path = tools_dir / f"{name}.md"
    if md_path.exists():
        return md_path.stat().st_size / 1024
    return 0.1  # Default if no .md file


def compute_metrics(tools_dir: Path, name: str, est: dict) -> dict:
    """Compute derived metrics from input estimates."""
    enablement = est["essentiality"] * est["frequency"]
    turn_efficiency = est["turns_without"] / est["turns_with"]
    accuracy_boost = (1 - est["error_with"]) / (1 - est["error_without"])
    penalty = est["substitutability"] ** 0.322

    benefit = enablement * turn_efficiency * accuracy_boost * (1 - penalty)
    definition_kb = get_definition_kb(tools_dir, name)
    cost = definition_kb + (est["call_kb"] * est["frequency"])

    value = benefit / cost  # benefit per kB

    return {
        "name": name,
        "enablement": enablement,
        "turn_efficiency": turn_efficiency,
        "accuracy_boost": accuracy_boost,
        "penalty": penalty,
        "benefit": benefit,
        "cost": cost,
        "value": value,
    }


def main():
    tools_dir = Path(__file__).parent.parent

    results = {}
    for yaml_path in sorted(tools_dir.glob("*.yaml")):
        if yaml_path.name.endswith(".score.yaml"):
            continue
        name = yaml_path.stem
        est = yaml.safe_load(yaml_path.read_text())
        m = compute_metrics(tools_dir, name, est)
        sf = lambda x: float(f"{x:.3g}")
        results[name] = {
            "enablement": sf(m["enablement"]),
            "turn_efficiency": sf(m["turn_efficiency"]),
            "accuracy_boost": sf(m["accuracy_boost"]),
            "penalty": sf(m["penalty"]),
            "benefit": sf(m["benefit"]),
            "cost": sf(m["cost"]),
            "value": sf(m["value"]),
        }

    print(yaml.dump(results, sort_keys=False, default_flow_style=False))


if __name__ == "__main__":
    main()
