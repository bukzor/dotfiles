#     return 0.1  # Default if no .md file


def compute_metrics(name: str, est: dict) -> dict:
    """Compute derived metrics from input estimates."""
    enablement = est["essentiality"] * est["frequency"]
    turn_efficiency = est["turns_without"] / est["turns_with"]
    accuracy_boost = (1 - est["error_with"]) / (1 - est["error_without"])
    penalty = est["substitutability"] ** 0.322

    benefit = enablement * turn_efficiency * accuracy_boost * (1 - penalty)
    cost = est["definition_kb"] + (est["call_kb"] * est["frequency"])

    value = benefit / cost  # benefit per kB

    return {
        "name": name,
        "enablement": enablement,
        "turn_efficiency": turn_efficiency,
        "accuracy_boost": accuracy_boost,
        "penalty": penalty,
        "benefit": benefit,
        "cost": cost,
        "value": value,
    }


def main():
    tools_dir = Path(__file__).parent

    results = {}
    for yaml_path in sorted(tools_dir.glob("*.yaml")):
        if yaml_path.name.endswith(".score.yaml"):
            continue
        name = yaml_path.stem
        est = yaml.safe_load(yaml_path.read_text())
        m = compute_metrics(name, est)
        results[name] = {
            "enablement": round(m["enablement"], 3),
            "turn_efficiency": round(m["turn_efficiency"], 2),
            "accuracy_boost": round(m["accuracy_boost"], 3),
            "penalty": round(m["penalty"], 3),
            "benefit": round(m["benefit"], 3),
            "cost": round(m["cost"], 2),
            "value": round(m["value"], 2),
        }

    print(yaml.dump(results, sort_keys=False, default_flow_style=False))


if __name__ == "__main__":
    main()
