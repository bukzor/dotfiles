#!/bin/bash
set -euo pipefail
export DEBUG="${DEBUG:-0}"

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( DEBUG > 0 )); then
  set -x
fi

cd "$(dirname "$0")"
workdir="$(mktemp -d)"
fakehome="$(mktemp -d)"

# Delayed cleanup: setsid detaches from process group so it survives test exit
setsid sh -c "sleep 10800; rm -rf '$workdir' '$fakehome'" >/dev/null 2>&1 &  # 3 hours

# Set up fake home with only the skill definition and credentials
mkdir -p "$fakehome/.claude/skills/llm.kb"
cp ~/.claude/skills/llm.kb/SKILL.md "$fakehome/.claude/skills/llm.kb/"
ln -s ~/.claude/.credentials.json "$fakehome/.claude/"

# Set up working directory
cp -ar . "$workdir"
cd "$workdir"

# Override CLAUDE.md if specified
[[ -n "${CLAUDE_MD:-}" ]] && cp "$CLAUDE_MD" CLAUDE.md

echo "## Working directory: $workdir"
echo "## Fake home: $fakehome"
echo "## CLAUDE.md: ${CLAUDE_MD:-CLAUDE.md}"

allowed='Read Write Edit(*) Bash(mkdir:*) Bash(cat:*) Bash(tail:*) Glob Skill'

echo "## kb-writer: Create knowledge base"
HOME="$fakehome" claude -p 'Execute the task in CLAUDE.md' \
    --output-format stream-json \
    --verbose \
    --model haiku \
    --add-dir "$workdir" \
    --allowedTools "$allowed" \
  > claude-session.kb-writer.jsonl
tail -1 claude-session.kb-writer.jsonl |
  claude-jsonl-display

echo "## kb-writer artifacts:"
find . -type f -print0 |
  xargs -0 wc

echo "## kb-reader: Test multi-agent handoff"
# Remove task prompt so kb-reader can't cheat — must discover via .kb/ pattern
rm CLAUDE.d/movie-tracker.md

HOME="$fakehome" claude -p 'What sci-fi movies have I watched?' \
    --output-format stream-json \
    --verbose \
    --model haiku \
    --add-dir "$workdir" \
    --allowedTools "$allowed" \
  > claude-session.kb-reader.jsonl
tail -1 claude-session.kb-reader.jsonl |
  claude-jsonl-display

# Validate kb-reader response content
reader_response=$(
  tail -1 claude-session.kb-reader.jsonl |
    jq -r '.result.resultText // .message.content // empty'
)
if grep <<<"$reader_response" -qiE '(watched \*\*2|2 sci-fi|watched 2|two sci-fi)'; then
  echo "## kb-reader validation: ✓ PASS (found movie data)"
elif grep <<<"$reader_response" -qiE "(don't have|doesn't exist|no data|no information|cannot access|not found)"; then
  echo "## kb-reader validation: ✗ FAIL (didn't discover .kb/ data)"
  exit 1
else
  echo "## kb-reader validation: ? UNKNOWN (unexpected response)"
  echo "## Response: $reader_response"
  exit 1
fi

echo "## Final artifacts:"
find . -type f -print0 | xargs -0 wc
