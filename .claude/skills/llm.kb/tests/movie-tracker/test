#!/bin/bash
set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

cd "$(dirname "$0")"
workdir="$(mktemp -d)"
fakehome="$(mktemp -d)"

# Delayed cleanup: setsid detaches from process group so it survives test exit
setsid sh -c "sleep 10800; rm -rf '$workdir' '$fakehome'" >/dev/null 2>&1 &  # 3 hours

# Set up fake home with only the skill definition and credentials
mkdir -p "$fakehome/.claude/skills/llm.kb"
cp ~/.claude/skills/llm.kb/SKILL.md "$fakehome/.claude/skills/llm.kb/"
ln -s ~/.claude/.credentials.json "$fakehome/.claude/"

# Set up working directory
cp -ar . "$workdir"
cd "$workdir"

# Override CLAUDE.md if specified
[[ -n "${CLAUDE_MD:-}" ]] && cp "$CLAUDE_MD" CLAUDE.md

echo "## Working directory: $workdir"
echo "## Fake home: $fakehome"
echo "## CLAUDE.md: ${CLAUDE_MD:-CLAUDE.md}"

allowed='Read Write Edit(*) Bash(mkdir:*) Bash(cat:*) Bash(tail:*) Glob Skill'

echo "## Phase 1: Create knowledge base"
HOME="$fakehome" claude -p 'Execute the task in CLAUDE.md' \
    --output-format stream-json \
    --verbose \
    --model haiku \
    --add-dir "$workdir" \
    --allowedTools "$allowed" \
  > claude-session.jsonl
tail -1 claude-session.jsonl | claude-jsonl-display

echo "## Phase 1 artifacts:"
find . -type f -print0 | xargs -0 wc

echo "## Phase 2: Test multi-agent handoff"
rm CLAUDE.d/movie-tracker.md

HOME="$fakehome" claude -p 'What sci-fi movies have I watched?' \
    --output-format stream-json \
    --verbose \
    --model haiku \
    --add-dir "$workdir" \
    --allowedTools "$allowed" \
  >> claude-session.jsonl
tail -1 claude-session.jsonl | claude-jsonl-display

# Validate Phase 2 response content
phase2_response=$(tail -1 claude-session.jsonl | jq -r '.result.resultText // .message.content // empty' 2>/dev/null)
if echo "$phase2_response" | grep -qiE '(watched \*\*2|2 sci-fi|watched 2|two sci-fi)'; then
  echo "## Phase 2 validation: ✓ PASS (found movie data)"
elif echo "$phase2_response" | grep -qiE "(don't have|doesn't exist|no data|no information|cannot access|not found)"; then
  echo "## Phase 2 validation: ✗ FAIL (agent didn't read CLAUDE.d/)"
  exit 1
else
  echo "## Phase 2 validation: ? UNKNOWN (unexpected response)"
  echo "## Response: $phase2_response"
  exit 1
fi

echo "## Final artifacts:"
find . -type f -print0 | xargs -0 wc
