#!/bin/bash
# Test CLAUDE.md instruction variations
set -euo pipefail
cd "$(dirname "$0")"

exec > >(tee test-variations.log) 2>&1

trials="${1:-4}"  # ~30 total across all variants

ncpu=$(nproc)
parallel -j $((ncpu * 2)) --tag \
  'CLAUDE_MD={1} ./test' \
  ::: variants/*.md \
  ::: $(seq 1 "$trials")
