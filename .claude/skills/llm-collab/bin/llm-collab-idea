#!/bin/bash
# Create new idea file with auto-incrementing number

set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

# Locate skeleton directory
HERE="$(cd "$(dirname "$0")"; pwd)"
SKILL_DIR="$(cd "$HERE/.." && pwd)"
SKELETON="$SKILL_DIR/skeleton"

if [ -z "${1:-}" ]; then
  echo >&2 "Usage: llm-collab-idea \"Idea title\""
  echo >&2 "       DATE=YYYY-MM-DD llm-collab-idea \"Idea title\"  (for backdating)"
  exit 1
fi

TITLE="$*"

# Ensure we're in project root
if [ ! -d ".claude" ]; then
  echo >&2 "Error: .claude/ not found in $PWD"
  echo >&2 "If this is the right location, run: mkdir -p .claude/ideas.d && !!"
  exit 1
fi

mkdir -p .claude/ideas.d

DATE=${DATE:-$(date +%Y-%m-%d)}
LAST=$(find .claude/ideas.d -maxdepth 1 -name "$DATE-*" -print0 2>/dev/null | xargs -r0 ls -1t | sed -n '1p' || echo "")

if [ -z "$LAST" ]; then
  NUM="000"
else
  # Extract number after date prefix, handle leading zeros properly
  NUM=$(basename "$LAST" | sed -E "s/^$DATE-([0-9]{3})-.*/\1/")
  NUM=$(printf "%03d" $((10#$NUM + 1)))
fi

# Create slug from title
SLUG=$(echo "$TITLE" | tr ' ' '-' | tr '[:upper:]' '[:lower:]' | tr -cd '[:alnum:]-')
FILE=".claude/ideas.d/$DATE-$NUM-$SLUG.md"

sed -e "s/Example Idea Title/$TITLE/g" -e "s/YYYY-MM-DD/$DATE/g" \
    "$SKELETON/.claude/ideas.d/YYYY-MM-DD-000-example-idea.md" > "$FILE"

echo "Created $FILE"
