#!/bin/bash
# Initialize LLM-collaborative documentation structure

set -euo pipefail

onerror() {
  error="$?"
  echo >&2 "ERROR($error)"
  exit "$error"
}
trap onerror ERR

if (( ${DEBUG:-0} > 0 )); then
  set -x
fi

usage() {
  echo >&2 "Usage: llm-collab-init [PROJECT_ROOT]"
  echo >&2 "       Initialize LLM-collaborative documentation structure"
  echo >&2 "       PROJECT_ROOT defaults to current directory"
}

while [[ "${1:-}" == -* ]]; do
  case "$1" in
    -h|--help) usage; exit 0 ;;
    *) echo >&2 "Unknown option: $1"; exit 1 ;;
  esac
done

PROJECT_ROOT=${1:-.}
cd "$PROJECT_ROOT"

# Locate skeleton directory
HERE="$(cd "$(dirname "$0")"; pwd)"
SKILL_DIR="$(cd "$HERE/.." && pwd)"
SKELETON="$SKILL_DIR/skeleton"

echo "🚀 Initializing LLM-collaborative documentation structure..."

# Migrate old docs/adr to docs/dev/adr if needed
if [ -d "docs/adr" ]; then
  if [ -d "docs/dev/adr" ]; then
    echo >&2 "Error: Both docs/adr/ and docs/dev/adr/ exist - manual resolution required"
    exit 1
  fi
  echo "⚠️  Found docs/adr/ - migrating to docs/dev/adr/"
  mkdir -p docs/dev
  if git mv docs/adr docs/dev/adr 2>/dev/null; then
    echo "✅ Migrated docs/adr/ → docs/dev/adr/ (git mv)"
  else
    mv docs/adr docs/dev/adr
    echo "✅ Migrated docs/adr/ → docs/dev/adr/ (mv)"
  fi
fi

# Migrate old docs/devlog to docs/dev/devlog if needed
if [ -d "docs/devlog" ]; then
  if [ -d "docs/dev/devlog" ]; then
    echo >&2 "Error: Both docs/devlog/ and docs/dev/devlog/ exist - manual resolution required"
    exit 1
  fi
  echo "⚠️  Found docs/devlog/ - migrating to docs/dev/devlog/"
  mkdir -p docs/dev
  if git mv docs/devlog docs/dev/devlog 2>/dev/null; then
    echo "✅ Migrated docs/devlog/ → docs/dev/devlog/ (git mv)"
  else
    mv docs/devlog docs/dev/devlog
    echo "✅ Migrated docs/devlog/ → docs/dev/devlog/ (mv)"
  fi
fi

# Create directory structure
mkdir -p docs/dev/{adr,devlog}
mkdir -p docs/{architecture,milestones,examples}

echo "✅ Created directory structure"

# Create CLAUDE.md
if [ ! -f CLAUDE.md ]; then
  cp "$SKELETON/CLAUDE.md" CLAUDE.md
  echo "✅ Created CLAUDE.md"
fi

# Create ROADMAP.md
if [ ! -f ROADMAP.md ]; then
  cp "$SKELETON/ROADMAP.md" ROADMAP.md
  echo "✅ Created ROADMAP.md"
fi

# Create CONTRIBUTING.md
if [ ! -f CONTRIBUTING.md ]; then
  cp "$SKELETON/CONTRIBUTING.md" CONTRIBUTING.md
  echo "✅ Created CONTRIBUTING.md"
fi

# Create docs/dev/adr/CLAUDE.md
if [ ! -f docs/dev/adr/CLAUDE.md ]; then
  cp "$SKELETON/docs/dev/adr/CLAUDE.md" docs/dev/adr/CLAUDE.md
  echo "✅ Created docs/dev/adr/CLAUDE.md"
fi

# Create docs/dev/devlog/CLAUDE.md
if [ ! -f docs/dev/devlog/CLAUDE.md ]; then
  cp "$SKELETON/docs/dev/devlog/CLAUDE.md" docs/dev/devlog/CLAUDE.md
  echo "✅ Created docs/dev/devlog/CLAUDE.md"
fi

# Create docs/architecture/overview.md
if [ ! -f docs/architecture/overview.md ]; then
  cp "$SKELETON/docs/architecture/overview.md" docs/architecture/overview.md
  echo "✅ Created docs/architecture/overview.md"
fi

echo "✅ Helper scripts available at: $SKILL_DIR/bin/"

# Create first devlog entry (only for brand-new projects)
# After migration, check for any existing entries (old or new naming format)
if ! find docs/dev/devlog -maxdepth 1 -type f -name "*.md" ! -name "CLAUDE.md" ! -name "README.md" | grep -q .; then
  "$HERE/llm-collab-devlog" "Project initialization"
  echo "✅ Created first devlog entry"
fi

echo ""
echo "🎉 Documentation structure initialized!"
echo ""
echo "Next steps:"
echo "  1. Edit CLAUDE.md with project-specific guidance"
echo "  2. Create ADRs: llm-collab-adr \"Your decision\""
echo "  3. Create devlogs: llm-collab-devlog"
