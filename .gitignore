# ---------------------------------------------------------------------------
# Windows user profile (host is %USERPROFILE%, never VCS)
# ---------------------------------------------------------------------------

# Registry hives and transactional logs
NTUSER.DAT
NTUSER.DAT{*}.TxR.*
NTUSER.DAT{*}.TM*
ntuser.dat.LOG*
ntuser.ini

# Windows-XP-era backward-compat junctions (inaccessible reparse points)
/Application Data
/Cookies
/Local Settings
/My Documents
/NetHood
/PrintHood
/Recent
/SendTo
/Start Menu
/Templates

# Other host-local Windows state
.wslconfig
.git-for-windows-updater
_viminfo

