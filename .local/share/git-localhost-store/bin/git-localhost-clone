#!/bin/bash
# git-localhost-clone: like `git clone URL DIR`, but attaches to any
# existing store for DIR *before* fetching.
#
# Why: plain `git clone` into a path whose store survived a prior `rm -r`
# of the workdir creates a *second*, independent set of refs. By the time
# our hooks see it (after clone finishes), both the store and the fresh
# .git have committed history, and git-localhost-store correctly refuses
# to guess which should win. Attaching to the store first — via the
# existing recovery path in git-localhost-store, which fires cleanly on
# a ref-less .git — means there is only ever one set of refs: fetch just
# updates refs/remotes/origin/* (always safe), and any local-branch vs.
# origin divergence is left for a human/agent to resolve explicitly,
# same as resuming any ordinary existing clone.
#
# Scope (MVP): single default branch, no --branch/--depth/--recurse-submodules.
# For those, use plain `git clone` (accepting the fresh-store code path).
set -euo pipefail
export PS4=$'\e[36m$\e[0m '

if [ $# -ne 2 ]; then
    echo "usage: git-localhost-clone URL DIR" >&2
    exit 1
fi
url="$1"
dir="$2"
here="$(dirname "$(readlink -f "$0")")"

if [ -e "$dir" ] && [ -n "$(ls -A "$dir" 2>/dev/null)" ]; then
    echo "git-localhost-clone: ❌ destination '$dir' already exists and is not empty" >&2
    exit 1
fi

mkdir -p "$dir"
(cd "$dir" && git init -q)
(cd "$dir" && "$here/git-localhost-store")

cd "$dir"
if ! git remote get-url origin >/dev/null 2>&1; then
    git remote add origin "$url"
fi
git fetch origin

if ! git remote set-head origin -a >/dev/null 2>&1; then
    echo "git-localhost-clone: origin has no HEAD (empty repo?) -- nothing to check out" >&2
    exit 0
fi
default_branch="$(git symbolic-ref --short refs/remotes/origin/HEAD)"
default_branch="${default_branch#origin/}"

if git rev-parse --verify -q "refs/heads/$default_branch" >/dev/null; then
    echo "git-localhost-clone: local branch '$default_branch' already existed (recovered from store) -- not auto-resetting onto origin. Compare and reconcile manually:" >&2
    git --no-pager log --oneline -1 "refs/heads/$default_branch" >&2
    git --no-pager log --oneline -1 "refs/remotes/origin/$default_branch" >&2
else
    git checkout -q -b "$default_branch" --track "origin/$default_branch"
fi

git ls-files --deleted -z | xargs -0r git restore --
