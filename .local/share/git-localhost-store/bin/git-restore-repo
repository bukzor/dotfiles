#!/bin/bash
# git-localhost-store: relocate .git to a central store, leave a symlink.
# Goal: keep `.git/HEAD` (and friends) readable via path resolution, so naive
# tools (e.g. lazy.nvim) work unchanged.

set -euo pipefail
export PS4=$'\e[36m$\e[0m '

REPOS_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/git-localhost-store/repos"
WORK_DIR="$(git rev-parse --show-toplevel)"
ENCODED="$(claude-path "$WORK_DIR")"
STORE="$REPOS_ROOT/$ENCODED"

mkdir -p "$REPOS_ROOT"
chmod 700 "$REPOS_ROOT"

cd "$WORK_DIR"

if [ -L .git ]; then
    echo "✓ Already a symlink: $(readlink .git)" >&2
    exit 0
fi

if [ ! -d .git ]; then
    echo "❌ .git is not a directory (got: $(ls -ld .git 2>&1))" >&2
    exit 1
fi

if [ -e "$STORE" ]; then
    # Recovery: workdir was rm -rf'd, then re-init'd. Adopt the existing
    # store and restore tracked files. Refuse only if the fresh .git has
    # picked up commits (refs in heads or remotes) that would conflict.
    if [ -n "$(ls -A .git/refs/heads 2>/dev/null)" ] \
       || [ -n "$(ls -A .git/refs/remotes 2>/dev/null)" ]; then
        echo "❌ .git has refs but store already exists: $STORE" >&2
        echo "   Refusing to merge. Resolve manually." >&2
        exit 1
    fi
    (set -x
        rm -r .git
        ln -s "$STORE" .git
    )
    git ls-files --deleted -z | xargs -0r git restore --
    echo "✓ Recovered: .git -> $STORE" >&2
    exit 0
fi

(set -x
    mv .git "$STORE"
    ln -s "$STORE" .git
)

echo "✓ Relocated .git -> $STORE" >&2
