#!/bin/bash
# Link to path-encoded object store in XDG_STATE_HOME

set -euo pipefail

# Pretty trace output
export PS4=$'\e[36m$\e[0m '

REPOS_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/git-localhost-store/repos"
WORK_DIR="$(git rev-parse --show-toplevel 2>/dev/null || pwd)"
ENCODED=$(claude-path "$WORK_DIR")
OBJECT_STORE="$REPOS_ROOT/$ENCODED"

mkdir -p "$REPOS_ROOT"
chmod 700 "$REPOS_ROOT"

# Check if .git is effectively empty (no commits, no branches)
git_is_empty() {
    [ ! -d .git/refs/heads ] || [ -z "$(ls -A .git/refs/heads 2>/dev/null)" ]
}

WORKTREE_NAME=$(basename "$WORK_DIR")
WORKTREE_DIR="$OBJECT_STORE/worktrees/$WORKTREE_NAME"

# Initialize object store if needed
if [ ! -d "$OBJECT_STORE" ]; then
    echo "✓ Creating object store: $OBJECT_STORE" >&2
    (set -x
        mv .git "$OBJECT_STORE"
        git config -f "$OBJECT_STORE/config" core.bare true
    )
else
    echo "✓ Found existing object store - recovering..." >&2

    if ! git_is_empty; then
        echo "❌ .git has existing commits but object store exists" >&2
        echo "   Cannot safely merge - manual intervention required" >&2
        exit 1
    fi

    (set -x; rm -rf .git)
fi

# Set up worktree structure
(set -x
    mkdir -p "$WORKTREE_DIR"
    echo "$WORK_DIR/.git" > "$WORKTREE_DIR/gitdir"
    echo "../.." > "$WORKTREE_DIR/commondir"
)

if [ -f "$OBJECT_STORE/HEAD" ]; then
    cp "$OBJECT_STORE/HEAD" "$WORKTREE_DIR/HEAD"
fi

mkdir -p "$WORKTREE_DIR/refs"

# Preserve index if it exists (may have been written before this hook ran)
if [ -f "$OBJECT_STORE/index" ]; then
    mv "$OBJECT_STORE/index" "$WORKTREE_DIR/index"
fi

echo "gitdir: $WORKTREE_DIR" > .git

# If branches exist, restore deleted files
if git show-ref --heads >/dev/null 2>&1; then
    # Only restore files that were tracked but are now missing
    git ls-files --deleted |
      tr '\n' '\0' |
      xargs -0r sh -xc 'git restore "$@"' -
fi
