#!/bin/bash
# List working directories whose .git is a gitfile pointing into this
# system's store — candidates for `migrate-from-gitfile`.
#
# Usage: audit-gitfiles [root]   # default root: $HOME
set -euo pipefail

STORE_PARENT="${XDG_STATE_HOME:-$HOME/.local/state}/git-localhost-store"
ROOT="${1:-$HOME}"

find "$ROOT" \( -type d \! -readable -prune \) \
  -o \( -type f -name .git -print0 \) |
  while IFS= read -r -d '' f; do
    line=$(sed -n '1p' "$f")
    case "$line" in
      "gitdir: $STORE_PARENT"/*) dirname "$f" ;;
    esac
  done
