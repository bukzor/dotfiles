#!/bin/bash
# git-localhost-store: convert .git to symlink after refs land.
# State $1: prepared (locks held), committed (safe), aborted

set -euo pipefail
export DEBUG="${DEBUG:-0}"

if (( DEBUG > 0 )); then
  set -x
  : reference-transaction "$@"
fi

if [[ "${1:-}" != "committed" ]]; then
  exit 0
fi

if [ -L .git ] || [ -f .git ]; then
  : Nothing to convert.
  exit 0
fi

# No refs yet (fresh init) — let post-index-change / pre-commit handle it.
if [ -z "$(ls -A .git/refs/heads 2>/dev/null)" ] \
   && [ -z "$(ls -A .git/refs/remotes 2>/dev/null)" ]; then
  exit 0
fi

"${XDG_DATA_HOME:-$HOME/.local/share}/git-localhost-store/bin/git-localhost-store"
