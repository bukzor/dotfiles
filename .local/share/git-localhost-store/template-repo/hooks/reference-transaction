#!/bin/bash
# Ensure object store is set up after ref transactions complete
# State $1: prepared (locks held), committed (safe), aborted

set -euo pipefail
export DEBUG="${DEBUG:-0}"

if (( DEBUG > 0 )); then
  echo >&2 "reference-transaction: state='${1:-}'"
  set -x
fi

if [[ "${1:-}" != "committed" ]]; then
  # Only act after transaction completes
  exit 0
elif [ ! -d .git ]; then
  # Already converted to worktree
  exit 0
elif [ -z "$(ls -A .git/refs/heads 2>/dev/null)" ]; then
  # Fresh git init (no branches yet) - let post-index-change handle it
  exit 0
else
  "${XDG_DATA_HOME:-$HOME/.local/share}/git-localhost-store/bin/git-restore-repo"
fi
