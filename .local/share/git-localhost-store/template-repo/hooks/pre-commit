#!/bin/bash
# git-localhost-store: catch fresh-init repos before first commit.

set -euo pipefail

export DEBUG="${DEBUG:-0}"
if (( DEBUG > 0 )); then
  set -x
  : pre-commit "$@"
fi

if [ -L .git ] || [ -f .git ]; then
  : Nothing to convert.
  exit 0
fi

"${XDG_DATA_HOME:-$HOME/.local/share}/git-localhost-store/bin/git-localhost-store"
