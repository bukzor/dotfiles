#!/bin/bash
# Sync all refs to object store

set -euo pipefail

REPOS_ROOT="${XDG_STATE_HOME:-$HOME/.local/state}/git-localhost-store/repos"
WORK_DIR="$(git rev-parse --show-toplevel)"
ENCODED=$(claude-path "$WORK_DIR")
OBJECT_STORE="$REPOS_ROOT/$ENCODED"

if [ ! -d "$OBJECT_STORE" ]; then
    echo "❌ Object store not found: $OBJECT_STORE" >&2
    exit 1
fi

# Update refs in object store (objects are already there via alternates)
if ! git push "$OBJECT_STORE" --all 2>&1; then
    echo "❌ Failed to sync refs to object store" >&2
    exit 1
fi

if ! git push "$OBJECT_STORE" --tags 2>&1; then
    echo "❌ Failed to sync tags to object store" >&2
    exit 1
fi
