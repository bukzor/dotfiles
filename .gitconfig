[user]
    name = Buck Evan
    handle = bukzor

    # last wins
    email = buck.evan@sentry.io

[core]
    excludesfile = ~/.gitignore_global
[init]
    defaultBranch = main
[color]
    ui = auto
[pack]
    threads = 0
    packSizeLimit = 64m
[diff]
    renamelimit = 0
    tool = vimdiff
    algorithm = histogram
    # detect renames and copies by default
    renames = copy
    color-moved = zebra
    # relative = false  # break git-vimdiff otherwise
    relative = true  # less useful otherwise
    # SADFACE: these don't work (yet?)
    find-renames = 10%
    find-copies = 10%
    find-copies-harder = true
[difftool]
    prompt = false

[difftool "debug"]
    cmd = "echo ---; echo \"BASE:$BASE\"; echo \"LOCAL:$LOCAL\"; echo \"MERGED:$MERGED\"; echo \"REMOTE:$REMOTE\""
[difftool "vimdiff"]
    # unset GIT_EXTERNAL_DIFF, to allow :!git diff to work
    # unset GIT_DIR and GIT_WORK_TREE, because it confuses GitSigns badly
    # The `vim` command is the same that git would use by default, except
    # missing a -R (readonly) option.
    cmd = " \
        unset GIT_DIR GIT_WORK_TREE; \
        ${GIT_DIFFTOOL_VIM:-vim} -f -d -c \"wincmd l | cd $GIT_PREFIX\" \"$LOCAL\" \"$REMOTE\" \
    "
[merge]
    renamelimit = 0
    tool = vimmerge
    conflictstyle = diff3
[mergetool]
    prompt = false
    keepBackup = false
    trustExitCode = true
[mergetool "vimmerge"]
    cmd = "set -x; vimmerge $REMOTE $MERGED $LOCAL $BASE"
[push]
    default = current
    useForceIfIncludes = true
[pull]
    ff = only
[rebase]
    rebaseMerges = rebase-cousins
    # mark any 'fixup! ...' commits as fixup
    autoSquash = true
    # use reflog to pick a better base SHA
    forkPoint = true

    # Automatically force-update any branches that point to commits that are
    # being rebased. Any branches that are checked out in a worktree are not
    # updated in this way.
    updateRefs = true

[advice]
    detachedHead = false
[alias]
    ll = log --oneline --graph --decorate --color=always --pretty=format:%C(auto)%h\\ %C(bold\\ blue)%aE\\ %Cgreen(%cr)%C(auto)%d%Creset\\ %s
    l = !sh -ec 'git ll HEAD ^"$(git upstream)" "$@"' -
    xl = ll --all

    ff = merge --ff-only

    push-mine = !git-push-mine
    branch-name = symbolic-ref -q --short HEAD
    tag-name = !sh -exc 'git tag -l --points-at ${1:-HEAD}' -
    base = !sh -exc 'git merge-base "$(git upstream)" ${1:-HEAD}' -
    diffbase = !git diff $(git base)
    diff3 = !git range-diff "$(git upstream)"
    feature = !sh -ec 'b="bukzor/$1" && shift 1 && set -x && git master && git checkout -b "$b" "$@"' -
    is-clean = diff-index --quiet HEAD
    vimdiff = difftool
    dt = difftool
    d = diff
    mt = mergetool
    wip = commit -m 'WIP' --no-verify
    amend = commit --amend --no-edit
    amendall = amend --all
    co = checkout
    ci = commit
    top = rev-parse --show-toplevel
    s = status -s
    sha = !sh -exc 'git rev-parse ${1:-HEAD}' -
[http]
    cookiefile = ~/.gitcookies
[include]
    path = ./private-dotfiles/.gitconfig

[log]
    diffMerges = dense-combined
[safe]
    directory = /Users/buck/repo/getsentry/tacos-gha.hg
    directory = /Users/buck/repo/getsentry/tacos-gha.hg
    directory = /Users/buck/repo/getsentry/tacos-gha.hg2
    directory = /Users/buck/repo/getsentry/tacos-gha
[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

# vim:sts=4:sw=4:et:
