#!/usr/bin/env python3
"""Make Claude Code transcripts more readable"""

import json
import signal
import sys
from dataclasses import dataclass
from typing import Any, Generator, TypeGuard


Content = dict[str, Any]


@dataclass(frozen=True)
class State:
    """Track conversation state for numbering messages"""

    role: str
    msg_num: int
    sub_num: int

    def __str__(self) -> str:
        if self.sub_num > 0:
            sub_num = f".{self.sub_num}"
        else:
            sub_num = ""
        return f"[{self.msg_num}{sub_num}]"


# ANSI color codes
class Color:
    RED = "\033[31m"
    GREEN = "\033[32m"
    YELLOW = "\033[33m"
    BLUE = "\033[34m"
    MAGENTA = "\033[35m"
    CYAN = "\033[36m"

    class Bright:
        RED = "\033[91m"
        GREEN = "\033[92m"
        YELLOW = "\033[93m"
        BLUE = "\033[94m"
        MAGENTA = "\033[95m"
        CYAN = "\033[96m"

    RESET = "\033[0m"
    BOLD = "\033[1m"

    to_bright = {
        RED: Bright.RED,
        GREEN: Bright.GREEN,
        YELLOW: Bright.YELLOW,
        BLUE: Bright.BLUE,
        MAGENTA: Bright.MAGENTA,
        CYAN: Bright.CYAN,
    }


def is_content_list(val: Any) -> TypeGuard[list[Content]]:
    """TypeGuard to check if value is a list of dicts with string keys"""
    if not isinstance(val, list):
        return False
    for item in val:  # type: ignore[reportUnknownVariableType]
        if not isinstance(item, dict):
            return False
        for k in item.keys():  # type: ignore[reportUnknownVariableType]
            if not isinstance(k, str):
                return False
    return True


def prefix(text: str, p: str) -> str:
    """Prefix each line of text with p"""
    return "\n".join(p + line for line in text.split("\n"))


def format_boxed_message(
    label: str, content: str, state: State | str, color: str,
) -> str:
    """Format a message with a boxed header and colored border"""
    bright_color = Color.to_bright[color]
    return f"{bright_color}┌─ {state} {label}{Color.RESET}\n" + prefix(
        content, f"{color}│ {Color.RESET}"
    )

def normalize_contents(content: Any) -> list[Content]:
    """Normalize content to a list (wrap non-lists)"""
    if not is_content_list(content):
        if isinstance(content, str):
            content = [{"type": "text", "text": content}]
        else:
            content = [content]
        assert is_content_list(content), content
    return content


def format_unknown(
    label: str,
    data: Any,
    state: State,
    color: str = Color.RED,
) -> str:
    """Format unknown/unexpected data with a clear error indicator"""
    json_str = json.dumps(data, indent=2)
    return format_boxed_message(
        f"UNKNOWN ({label})", json_str, state, color
    )


def update_state(content: Content, state: State) -> State:
    """Update role and message counters. Turn number increments when role changes between user and assistant."""
    item_type = content.get("type")

    # Determine the role of this message
    if item_type == "user":
        content = content["message"]["content"]
        # User text messages are user role; tool results are part of assistant turn
        if isinstance(content, str) or (
            is_content_list(content)
            and content
            and content[0]["type"] != "tool_result"
        ):
            new_role = "user"
        else:
            new_role = "assistant"
    elif item_type == "assistant":
        new_role = "assistant"
    else:
        # system, stream_event, result don't change role
        return state

    # Increment turn number when role changes, otherwise increment sub-number
    if new_role != state.role and state.role != "":
        return State(new_role, state.msg_num + 1, 0)
    elif state.role == "":
        # First message with a role
        return State(new_role, 1, 0)
    else:
        return State(new_role, state.msg_num, state.sub_num + 1)


def format_stream_event(event_type: str) -> str:
    """Format stream event messages"""
    if event_type == "message_start":
        return f"{Color.YELLOW}⏵ Message starting...{Color.RESET}"
    elif event_type == "message_stop":
        return f"{Color.YELLOW}⏹ Message complete{Color.RESET}"
    else:
        raise ValueError(f"Unknown stream event type: {event_type}")


def format_snapshot(content: Content) -> str:
    """Format file history snapshot message"""
    snapshot = content["snapshot"]
    tracked = snapshot["trackedFileBackups"]
    num_files = len(tracked)

    if num_files == 0:
        return f"{Color.CYAN}▸ Snapshot (no files){Color.RESET}"
    elif num_files <= 3:
        files = ", ".join(tracked.keys())
        return f"{Color.CYAN}▸ Snapshot: {files}{Color.RESET}"
    else:
        files = list(tracked.keys())[:3]
        files_str = ", ".join(files)
        return (
            f"{Color.CYAN}▸ Snapshot: {files_str}... ({num_files} files){Color.RESET}"
        )


def format_system(content: Content) -> str:
    """Format system/session start message"""
    tools = ", ".join(content["tools"])
    return (
        f"{Color.BOLD}## SESSION START{Color.RESET}\n"
        f"## Session: {content['session_id']}\n"
        f"## Model: {content['model']}\n"
        f"## CWD: {content['cwd']}\n"
        f"## Tools: {tools}"
    )


def format_user_message(content: Content, state: State) -> str:
    """Format a single user message content block"""
    content_type = content["type"]

    if content_type == "text":
        text = content["text"]
        # Special case for user interruption
        if text.startswith("[Request interrupted by user"):
            return f"{Color.RED}✗ {state} {text}{Color.RESET}"
        else:
            return format_boxed_message("USER", text, state, Color.BLUE)
    elif content_type == "tool_result":
        is_error = content["is_error"]
        result_content = content["content"]
        if is_error:
            return format_boxed_message(
                "Tool Result ❌ ERROR", result_content, state, Color.RED
            )
        else:
            return format_boxed_message(
                "Tool Result ✓", result_content, state, Color.GREEN
            )
    else:
        return format_unknown("user_content", content, state)


def format_tool_use(content: Content, state: State) -> str:
    """Format a tool use block"""
    tool_name = content["name"]
    tool_input = content["input"]

    tool_lines = [f"{Color.Bright.MAGENTA}╔═ {state} Tool Call: {tool_name}{Color.RESET}"]
    for key, value in tool_input.items():
        tool_lines.append(f"{Color.MAGENTA}║ {key}: |{Color.RESET}")
        if isinstance(value, str):
            value_str = value
        else:
            value_str = json.dumps(value, indent=2)
        tool_lines.append(prefix(value_str, f"{Color.MAGENTA}║   {Color.RESET}"))

    return "\n".join(tool_lines)


def format_assistant_message(content: Content, state: State) -> str:
    """Format a single assistant message content block"""
    content_type = content["type"]

    if content_type == "text":
        return format_boxed_message(
            "ASSISTANT", content["text"], state, Color.CYAN
        )
    elif content_type == "tool_use":
        return format_tool_use(content, state)
    elif content_type == "thinking":
        return format_boxed_message(
            "THINKING 💭", content["thinking"], state, Color.YELLOW
        )
    else:
        return format_unknown("assistant_content", content, state)


def format_result(content: Content) -> str:
    """Format session result/end message"""
    duration = content["duration_ms"]
    num_turns = content["num_turns"]
    cost = content["total_cost_usd"]
    is_error = content["is_error"]
    permission_denials = content["permission_denials"]
    result_content = content["result"]

    status = (
        f"{Color.Bright.RED}❌ ERROR{Color.RESET}"
        if is_error
        else f"{Color.Bright.GREEN}✓ SUCCESS{Color.RESET}"
    )

    lines = [
        f"{Color.BOLD}## SESSION END{Color.RESET}",
        f"## Duration: {duration}ms ({num_turns} turns)",
        f"## Cost: ${cost}",
        f"## Status: {status}",
    ]

    if len(permission_denials) > 0:
        lines.append(f"## Permission denials: {len(permission_denials)}")
    else:
        pass  # No permission denials to report

    lines.append(
        format_boxed_message("", result_content, "FIN", Color.CYAN)
    )

    return "\n".join(lines)


def format_item(content: Content, state: State) -> Generator[tuple[str, State], None, None]:
    """Format a single transcript content, yielding (output, state) tuples"""
    item_type = content.get("type")

    if item_type == "stream_event":
        event_type: str = content["event"]["type"]
        yield format_stream_event(event_type), state

    elif item_type == "system":
        yield format_system(content), state

    elif item_type in ("user", "assistant"):
        contents = normalize_contents(content["message"]["content"])
        formatter = format_user_message if item_type == "user" else format_assistant_message
        for content in contents:
            yield formatter(content, state), state
            state = State(state.role, state.msg_num, state.sub_num + 1)

    elif item_type == "result":
        yield format_result(content), state

    elif item_type == "file-history-snapshot":
        yield format_snapshot(content), state

    elif item_type == "summary":
        summary_text = content["summary"]
        yield f"{Color.CYAN}▸ Summary: {summary_text}{Color.RESET}", state

    else:
        yield format_unknown("item_type", content, state), state


def main():
    # Restore default SIGPIPE handler (terminate on broken pipe, e.g., piping to head)
    signal.signal(signal.SIGPIPE, signal.SIG_DFL)

    state = State("", 0, 0)

    for line in sys.stdin:
        line = line.strip()
        if not line:
            continue

        try:
            content = json.loads(line)
        except json.JSONDecodeError as error:
            print("WARN: unable to decode json:", error, file=sys.stderr)
            print(" ", repr(line), file=sys.stderr)
            continue

        state = update_state(content, state)

        for output, state in format_item(content, state):
            print(output)


if __name__ == "__main__":
    main()
