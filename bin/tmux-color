#!/bin/bash
# Because i can never remember the proper tmux command.
if [[ $1 ]]; then
  BG="$1"
  shift 1

  if [[ $1 ]]; then
      FG="$1"
  elif [[ "$BG" -le 15 ]]; then
      FG="bg"
  else
      FG="terminal"
  fi
  shift 1

  style="${1:-bold}"
  if [[ "$FG" =~ "bg" || "$BG" = "fg" ]]; then
    style="reverse${style+,$style}"
    tmp_bg="$BG"
    BG="$FG"
    FG="$tmp_bg"
  fi
  shift 1

  if [[ "$BG" == "bg" ]]; then
    BG=terminal
  fi
  if [[ "$FG" == "fg" ]]; then
    FG=terminal
  fi

  : numbers must be prefixed with 'colour'
  case "$BG" in [0-9]*) BG=colour"$BG"; esac
  case "$FG" in [0-9]*) FG=colour"$FG"; esac

  set -x
  tmux -q set -s status-style "$style,fg=$FG,bg=$BG"
else
  set -x
  : show color options
  colortest256

  : show current value
  tmux show -s status-style
fi
