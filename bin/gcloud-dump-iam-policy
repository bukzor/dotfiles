#!/bin/bash
set -euo pipefail
export PS4=$'+ \033[31;1m$\033[m '

set -x

if [ -d organizations ]; then
  rm -r organizations
fi
gcloud-dump-org-iam

if [ -d folders ]; then
  rm -r folders
fi
gcloud-dump-folders-iam

if [ -d projects ]; then
  rm -r projects
fi
gcloud-dump-projects-iam

if [ -d roles ]; then
  rm -r roles
fi
gcloud-dump-roles
