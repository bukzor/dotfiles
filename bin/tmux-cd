#!/bin/bash
set -euo pipefail

# Get the target directory (default to $PWD if not provided)
target_dir="${1:-$PWD}"

# Resolve to absolute path
target_dir=$(cd "$target_dir" && pwd)


tmux=(
  tmux 
  # enable control mode for programmatic control
  -C
  # change the session working directory
  attach-session -c "$target_dir"
  # prevent environment updates
  -E
  # minimize side effects
  -f active-pane,ignore-size,read-only,no-output
)

window_number=$(tmux display-message -p '#I')
i=$((window_number - 2))
if (( i < 0 )); then
  i=0
fi

set -x
tmux set-option base-index "$i"

# </dev/null prevents "sessions should be nested with care" error
"${tmux[@]}" </dev/null >/dev/null
