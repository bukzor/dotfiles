#!/usr/bin/env python3
"""List open tasks across conventional locations under ~/repo and ~/.claude.

Pending tasks across conventional locations:
- `todo.md` / `sessions.kb/*.md` files: list open `- [ ]` lines
- `todo.kb/*.md` / `todo.d/*.md` / `CLAUDE.*Task*.md` files: prose procedures
  — their existence IS the signal, so emit the path unconditionally. If a
  `- [ ]` list happens to be present, list those too.

Dedup across git worktrees: group by (repo, path-within-repo) and keep the
member with the largest effective mtime. Effective mtime is the file's
last-commit time when the file is clean, else filesystem mtime — git
checkout sets filesystem mtime to checkout time (not commit time), so a
fresh sibling worktree would otherwise beat `main` on identical content.
Repo identity = `remote.origin.url` when set, else the absolute
`--git-common-dir`. Files outside any git repo group as themselves.
"""

from __future__ import annotations

import functools
import os
import re
import subprocess
import sys
from collections.abc import Iterable, Sequence
from pathlib import Path

ROOTS = (Path.home() / "repo", Path.home() / ".claude", Path.home() / "claude")

# Status values that take a file out of the open-task list.
#   - done: terminal state, work complete
#   - template: not a task instance; a skeleton/example of the task shape
SKIP_STATUSES = ("done", "template")

STATUS = re.compile(r"^status:\s*(\S+)", re.MULTILINE)
OPEN_TASK = re.compile(r"^ *- \[ \].*$", re.MULTILINE)
CLAUDE_TASK_NAME = re.compile(r"^CLAUDE\..*task.*\.md$", re.IGNORECASE)

# Parent-directory names whose direct children follow "one file = one task":
# the file's existence in this location is the open-task signal, regardless
# of whether the body contains `- [ ]` bullets. Parallels CLAUDE.*Task*.md
# semantics but keyed on location rather than filename.
EXISTENCE_IS_SIGNAL_PARENTS = ("todo.kb", "todo.d")


def list_candidates(roots: Sequence[Path]) -> list[Path]:
    cmd = [
        "find", *(str(r) for r in roots),
        # Prune `trash/` subtrees: convention is staging area for material
        # slated for deletion, not active backlog.
        "(", "-type", "d", "-name", "trash", "-prune", ")",
        "-or",
        "(",
        "-false",
        "-or", "-path", "*/.claude/todo.md",
        "-or", "-path", "*/.claude/todo.kb/*.md",
        "-or", "-path", "*/.claude/todo.d/*.md",
        "-or", "-path", "*/.claude/sessions.kb/*.md",
        "-or", "-iname", "CLAUDE.*Task*.md",
        ")",
        "-not", "-name", "CLAUDE.md",
        "-print0",
    ]
    out = subprocess.run(cmd, check=True, capture_output=True).stdout
    return [Path(os.fsdecode(p)) for p in out.split(b"\0") if p]


def find_worktree_root(path: Path) -> Path | None:
    for parent in (path, *path.parents):
        if (parent / ".git").exists():
            return parent
    return None


def git_config(root: Path, key: str) -> str:
    proc = subprocess.run(
        ["git", "-C", str(root), "config", "--get", key],
        capture_output=True, text=True,
    )
    return proc.stdout.strip() if proc.returncode == 0 else ""


def git_rev_parse(root: Path, arg: str) -> str:
    return subprocess.run(
        ["git", "-C", str(root), "rev-parse", arg],
        check=True, capture_output=True, text=True,
    ).stdout.strip()


@functools.cache
def repo_id_of_root(root: Path) -> str:
    url = git_config(root, "remote.origin.url")
    if url:
        return url
    common = git_rev_parse(root, "--git-common-dir")
    return str((root / common).resolve())


def group_key(path: Path) -> str:
    root = find_worktree_root(path)
    if root is None:
        return str(path)
    return f"{repo_id_of_root(root)}|{path.relative_to(root)}"


@functools.cache
def dirty_paths(root: Path) -> frozenset[str]:
    proc = subprocess.run(
        ["git", "-C", str(root), "status", "--porcelain", "-uall"],
        check=True, capture_output=True, text=True,
    )
    return frozenset(line[3:] for line in proc.stdout.splitlines())


def git_last_commit_time(root: Path, relpath: str) -> float | None:
    proc = subprocess.run(
        ["git", "-C", str(root), "log", "-1", "--format=%ct", "--", relpath],
        check=True, capture_output=True, text=True,
    )
    out = proc.stdout.strip()
    return float(out) if out else None


def effective_mtime(path: Path) -> float:
    """Last-commit time for clean files; filesystem mtime for dirty/untracked
    files and files outside any git repo. Falls back to mtime if a clean
    file has no commit history (shouldn't happen but be defensive)."""
    root = find_worktree_root(path)
    if root is None:
        return path.stat().st_mtime
    relpath = str(path.relative_to(root))
    if relpath in dirty_paths(root):
        return path.stat().st_mtime
    commit_time = git_last_commit_time(root, relpath)
    return commit_time if commit_time is not None else path.stat().st_mtime


def select_freshest(paths: Iterable[Path]) -> list[Path]:
    by_key: dict[str, Path] = {}
    by_key_time: dict[str, float] = {}
    for p in paths:
        key = group_key(p)
        t = effective_mtime(p)
        if key not in by_key or t > by_key_time[key]:
            by_key[key] = p
            by_key_time[key] = t
    return list(by_key.values())


def is_status_skip(body: str) -> bool:
    """True if frontmatter declares a status that excludes this file
    from the open-task list (see SKIP_STATUSES)."""
    head = "\n".join(body.splitlines()[:30])
    m = STATUS.search(head)
    return m is not None and m.group(1) in SKIP_STATUSES


def existence_is_signal(path: Path) -> bool:
    """True if the path's location/name marks it as a one-file-one-task
    entry whose existence is the open-task signal (regardless of body)."""
    return (
        path.parent.name in EXISTENCE_IS_SIGNAL_PARENTS
        or CLAUDE_TASK_NAME.match(path.name) is not None
    )


def format_section(path: Path, body: str) -> str | None:
    if is_status_skip(body):
        return None
    open_tasks = OPEN_TASK.findall(body)
    if not open_tasks and not existence_is_signal(path):
        return None
    return "\n".join([f"## {path}", *open_tasks])


def main() -> int:
    for path in select_freshest(list_candidates(ROOTS)):
        body = path.read_text(errors="replace")
        section = format_section(path, body)
        if section is not None:
            print(section)
    return 0


if __name__ == "__main__":
    sys.exit(main())
