#!/bin/bash
set -euo pipefail
export PS4=$'+ \033[32;92m$\033[m '

( # org custom roles:
  show gcloud organizations list --format='value(name)' |
    xargs -r -P50 --replace \
      show gcloud iam roles list --format json --organization={} \
  ;
  # project custom roles
  show gcloud projects list --format='value(projectId)' |
    xargs -r -P50 --replace \
      show gcloud iam roles list --format json --project={} \
  ;

  # built-in roles
  show gcloud iam roles list --format json
) |
  stdbuf -oL jq '.[] | .name' -r |
  xargs -P50 -L1 -r show gcloud-dump-role
