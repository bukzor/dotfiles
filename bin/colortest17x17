#!/usr/bin/env python3
from __future__ import annotations
from typing import Iterator, Iterable, TypeVar, Self

#
#   This file echoes a bunch of color codes to the
#   terminal to demonstrate what's available.  Each
#   line is the color code of one forground color,
#   out of 17 (default + 16 escapes), followed by a
#   test use of that color on all nine background
#   colors (default + 8 escapes).
#

T = TypeVar("T")
Several = tuple[T, ...]
TEXT = "1il"  # The test text
COLORS = tuple(range(8))
BG1S = (40, 100)  # bright backgrounds are invariably horrid.
FG1S = (30, 90)   # bright foregrounds are nonstandard and ugly
WIDTH = 7


class AnsiCode(frozenset[int]):
    def __str__(self):
        return ";".join(str(x) for x in sorted(self))

    def __or__(self, other: Iterable[int]) -> Self:
        cls = type(self)
        return cls(super().__or__(set(other)))

    def __format__(self, *args, **kwargs):
        return format(str(self), *args, **kwargs)

AnsiCodes = Several[AnsiCode]
INVERSE = AnsiCode({7})


def show_bgs(fg: AnsiCode, bg_styles: AnsiCodes, bg1s: Several[int]) -> Iterator[str]:
    yield f"{fg:>{WIDTH}} "
    for bg_style in bg_styles:
        yield f"\033[{fg | bg_style}m"
        yield TEXT.center(WIDTH)
    yield "\033[m "

    for bg2 in COLORS:
        for bg_style in bg_styles:
            for bg1 in bg1s:
                bg = AnsiCode({bg1 + bg2})
                color = fg | bg_style | bg
                yield f"\033[{color}m"
                yield TEXT.center(WIDTH)
        yield "\033[m "

    yield "\033[m\n"


def show_header(bg_styles: AnsiCodes, bg1s: Several[int]) -> Iterator[str]:
    yield " " * (WIDTH + 1)
    for bg_style in bg_styles:
        yield f"{bg_style:^{WIDTH}}"
    yield " "

    for bg2 in COLORS:
        for bg_style in bg_styles:
            for bg1 in bg1s:
                bg = bg_style | {bg1 + bg2}
                yield f"{bg:^{WIDTH}}"
        yield " "

    yield "\033[m\n"


def show_fgs(
    fg_styles: AnsiCodes, fg1s: Several[int], bg_styles: AnsiCodes, bg1s: Several[int]
) -> Iterator[str]:
    yield from show_header(bg_styles, bg1s)
    for fg_style in fg_styles:
        yield from show_bgs(fg_style, bg_styles, bg1s)
    for fg2 in COLORS:
        for fg1 in fg1s:
            for fg_style in fg_styles:
                fg = fg_style | {fg1 + fg2}
                yield from show_bgs(fg, bg_styles, bg1s)


def main():
    for x in show_fgs((AnsiCode(), AnsiCode({1})), FG1S, (AnsiCode(),), BG1S):
        print(x, end="")
    for x in show_fgs((AnsiCode(), AnsiCode({1})), BG1S, (AnsiCode({7}),), FG1S):
        print(x, end="")


if __name__ == "__main__":
    exit(main())
