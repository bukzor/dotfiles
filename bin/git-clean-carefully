#!/bin/bash
set -euo pipefail

src=$PWD
dirname=$(basename "$src")
mkdir -p "../$dirname.files/"
dst=$(mktemp -d "../$dirname.files/$(today).XXXX")

git clean -fdxfn | sed 's@Would remove @mkdir -p '"$dst"'/@; s@/[^/]*$@@' | uniq | sh -ex
git clean -fdxfn | sed -r 's@Would remove (.*)@mv \1 '"$dst"'/\1@; s@/[^/]+$@/@' | sh -ex
